# =============================================================================
# API Learning Hub — Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas el archivo .env al repositorio
# =============================================================================

# --- Entorno ---
NODE_ENV=development           # development | production | test

# --- Servidor Backend ---
PORT=3001
HOST=localhost

# --- Base de Datos ---
# SQLite (desarrollo local)
DATABASE_URL=file:./dev.db

# PostgreSQL (produccion) — descomenta y configura para produccion
# DATABASE_URL=postgresql://user:password@localhost:5432/api_learning_hub

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_de_al_menos_64_caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_secreto_diferente_muy_largo_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173   # URL del frontend en desarrollo

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000          # 1 minuto
RATE_LIMIT_MAX_REQUESTS=100         # Max requests por ventana (rutas generales)
RATE_LIMIT_AUTH_MAX=5               # Max intentos de login por ventana

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3001/api
VITE_APP_TITLE=API Learning Hub
