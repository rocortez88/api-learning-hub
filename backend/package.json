{
  "name": "api-learning-hub-backend",
  "version": "0.1.0",
  "description": "Backend del API Learning Hub — plataforma educativa de APIs",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env node_modules/.bin/tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.8",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@vitest/coverage-v8": "^1.5.0",
    "drizzle-kit": "^0.20.17",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.2",
    "vitest": "^1.5.0"
  }
}
